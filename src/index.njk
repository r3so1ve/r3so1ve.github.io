---
layout: base.njk
homepage: true
---
{% from "macros.njk" import sev, sevSquare, asciiRule %}
{% set posts = collections.posts %}
{% set featured = posts | featuredPost %}

<div class="status-strip">
  <div class="frame status-inner">
    <span class="status-cell"><span class="dot"></span><span class="lab">posts</span><span class="val">{{ posts | length }}</span></span>
    <span class="status-cell"><span class="lab">last write</span><span class="val">{% if posts | length %}{{ posts[0].date | timeAgo }}{% else %}—{% endif %}</span></span>
    {% if site.tzLabel %}<span class="status-cell"><span class="lab">tz</span><span class="val">{{ site.tzLabel }}</span></span>{% endif %}
  </div>
</div>

<section class="frame masthead">
  <div>
    <h1>
      <span class="title-line"><span class="prompt">&gt;_</span>Security<span class="accent">Forge</span></span>
      <span class="row2 sub">Cybersecurity <span class="pipe">|</span> Pentesting <span class="pipe">|</span> Vulnerability Research</span>
    </h1>
    <p class="lede">{{ site.description }}</p>
  </div>
  {% if posts | length %}
  <div class="maststats" aria-label="stats">
    <div><div class="k">posts</div><div class="v">{{ posts | length }}<small>longform</small></div></div>
    <div><div class="k">topics</div><div class="v">{{ (posts | tagList) | length }}<small>tags</small></div></div>
    <div><div class="k">words</div><div class="v">{{ posts | sumWords | compactNumber }}<small>archive</small></div></div>
    <div><div class="k">since</div><div class="v">{{ site.since or build.year }}<small>writing</small></div></div>
  </div>
  {% endif %}
</section>

<main class="frame">
  {% if posts | length == 0 %}
    <div style="padding:64px 0;text-align:center;color:var(--ink-mute);">
      {{ asciiRule("status · empty") }}
      <p style="font-family:var(--mono);font-size:13px;margin:18px 0;">No posts published yet. The first write-up is in progress.</p>
      <p style="font-size:12px;color:var(--ink-dim);">Check back soon, or subscribe via <a href="/feed.xml" style="color:var(--accent)">/feed.xml</a>.</p>
    </div>
  {% else %}
  <div class="main-grid">
    <div>
      {% if featured %}
      <div id="featuredWrap">
        {{ asciiRule("featured · pinned") }}
        <article class="featured">
          <div class="featured-diagram"></div>
          <div class="featured-body">
            <div class="meta">
              {{ sev(featured.data.sev) }}
              <span>{{ featured.date | isoDate }}</span>
              <span>· {{ featured.templateContent | readingTime }}</span>
              {% if featured.data.tag %}<span>· #{{ featured.data.tag }}</span>{% endif %}
            </div>
            <h2><a href="{{ featured.url }}">{{ featured.data.title }}</a></h2>
            <p class="summary">{{ featured.data.summary }}</p>
            {% if featured.data.topics %}<div class="tags">{% for t in featured.data.topics %}<span class="chip">#{{ t }}</span>{% endfor %}</div>{% endif %}
          </div>
        </article>
      </div>
      {% endif %}

      {{ asciiRule("archive · grep & filter") }}

      <div class="searchbar" role="search">
        <span class="pfx">~/$</span>
        <input id="searchInput" placeholder="grep posts — try: prompt injection, kerberos, idor…" aria-label="search posts" autocomplete="off">
        <span class="sfx"><span class="kbd">/</span> focus · <span class="kbd">esc</span> clear</span>
      </div>

      <div class="filterbar" id="filterBar" role="tablist" aria-label="tags">
        <button class="chip on" data-tag="all" role="tab" aria-selected="true">all<span class="ct">{{ posts | length }}</span></button>
        {% for t in posts | tagList %}<button class="chip" data-tag="{{ t.id }}" role="tab" aria-selected="false">{{ t.label }}<span class="ct">{{ t.count }}</span></button>{% endfor %}
      </div>

      <div class="section-head">
        <h3>// posts (<span id="visibleCount">{{ posts | length }}</span>)</h3>
        <span class="right">sorted: date desc</span>
      </div>

      <div class="archive" id="archive">
        {% for grp in posts | groupByYear %}
        <div class="year-block" data-year="{{ grp.year }}">
          <div class="year-head">
            <div class="y">{{ grp.year }}<small>· {{ grp.posts | length }} posts</small></div>
            <div class="summary-line">{{ grp.crit }} critical · {{ grp.high }} high · {{ grp.topics }} topics</div>
          </div>
          {% for p in grp.posts %}
          <a class="row" href="{{ p.url }}" data-tag="{{ p.data.tag }}" data-haystack="{{ (p.data.title ~ ' ' ~ p.data.summary ~ ' ' ~ p.data.tag ~ ' ' ~ p.data.sev) | lower }}">
            <span class="date">{{ p.date | isoDate }}</span>
            {{ sevSquare(p.data.sev) }}
            <span class="titlewrap"><span class="title">{{ p.data.title }}</span><span class="inlinetag">#{{ p.data.tag }}</span></span>
            <span class="read">{{ p.templateContent | readingTime }} →</span>
          </a>
          {% endfor %}
        </div>
        {% endfor %}
      </div>

      <div id="noResults" hidden style="padding:40px 0;text-align:center;color:var(--ink-mute);font-size:13px;">
        <div style="font-size:11px;letter-spacing:0.16em;color:var(--ink-dim);margin-bottom:6px;">0 RESULTS</div>
        no posts match those filters · <button id="resetFilters" type="button" style="color:var(--accent);text-decoration:underline;background:none;border:none;cursor:pointer;">reset</button>
      </div>

      <div style="margin-top:24px;padding:14px 16px;border:1px dashed var(--line);font-size:11px;color:var(--ink-mute);display:flex;justify-content:space-between;">
        <span>EOF · <span id="eofCount">{{ posts | length }}</span> of {{ posts | length }} posts</span>
        <span>↑ <a href="#top" style="border-bottom:1px dotted var(--ink-dim)">back to top</a></span>
      </div>
    </div>

    <aside class="side">
      <section class="panel">
        <div class="panel-head"><span>// about</span><span class="dotrow"><span></span><span></span><span></span></span></div>
        <div class="panel-body about">
          <p>{{ site.about }}</p>
          <ul>
            <li><span class="k">focus</span><span class="v">{{ site.focus }}</span></li>
            {% if site.github %}<li><span class="k">github</span><span class="v"><a href="{{ site.github }}">{{ site.githubLabel or site.github }}</a></span></li>{% endif %}
            {% if site.email %}<li><span class="k">contact</span><span class="v"><a href="mailto:{{ site.email }}">{{ site.email }}</a></span></li>{% endif %}
          </ul>
          {% if site.pgp.fingerprint %}<div class="fingerprint"><span class="label">PGP</span>{{ site.pgp.fingerprint | safe }}</div>{% endif %}
        </div>
      </section>

      {% if posts | length %}
      <section class="panel">
        <div class="panel-head"><span>// activity</span><span class="dotrow"><span></span><span></span><span></span></span></div>
        <div class="panel-body">
          <div class="activity">
            {% for p in posts | head(4) %}<div class="activity-row"><span class="when">{{ p.date | timeAgo }}</span><span class="what">published <em><a href="{{ p.url }}" style="color:inherit">{{ p.data.title | truncate(46) }}</a></em></span></div>{% endfor %}
          </div>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head"><span>// severity index</span><span class="dotrow"><span></span><span></span><span></span></span></div>
        <div class="panel-body">
          {% set sd = posts | severityData %}
          <div style="display:grid;gap:6px;">
            {% for r in sd.rows %}
            <div style="display:grid;grid-template-columns:70px 1fr 24px;gap:8px;align-items:center;font-size:11px;">
              {{ sev(r.s) }}
              <div style="height:6px;background:var(--bg-soft);border:1px solid var(--line-soft);">
                <div style="height:100%;width:{{ (r.n / sd.max * 100) | round }}%;background:var(--{% if r.s=='critical' %}crit{% elif r.s=='high' %}high{% elif r.s=='medium' %}med{% elif r.s=='low' %}low{% else %}info{% endif %});"></div>
              </div>
              <span style="color:var(--ink);text-align:right;font-variant-numeric:tabular-nums;">{{ r.n }}</span>
            </div>
            {% endfor %}
          </div>
        </div>
      </section>
      {% endif %}
    </aside>
  </div>
  {% endif %}
</main>
